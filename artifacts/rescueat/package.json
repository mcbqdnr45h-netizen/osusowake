{
  "name": "@workspace/rescueat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:cap": "vite build --config vite.config.cap.ts && mv dist-cap/index.cap.html dist-cap/index.html",
    "cap:gen-assets": "npx @capacitor/assets generate --iconBackgroundColor '#F26419' --iconBackgroundColorDark '#F26419' --splashBackgroundColor '#FBFBFA' --splashBackgroundColorDark '#1a1a1a'",
    "cap:sync": "pnpm run build:cap && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:add-ios": "npx cap add ios",
    "ios:setup": "bash scripts/ios-setup.sh",
    "ios:update": "pnpm run build:cap && npx cap copy ios",
    "ios:run": "pnpm run build:cap && npx cap run ios"
  },
  "devDependencies": {
