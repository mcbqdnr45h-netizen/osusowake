.env.local
dist-cap/

# iOS Capacitor — ビルド生成物・Pods のみ除外
# ci_scripts/ は Xcode Cloud に必要なため git 管理対象
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/.build/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/.DS_Store

# Android Capacitor — ビルド生成物・keystore は除外 (ソースは git 管理)
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/captures/
android/app/release/
android/app/debug/
# ⚠️ keystore / Firebase credentials は絶対 commit させない
android/*.keystore
android/*.jks
android/key.properties
android/app/google-services.json
